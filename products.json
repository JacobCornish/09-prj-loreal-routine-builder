<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>L'Oréal | Routine Builder</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"/>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <div class="page-wrapper">

      <!-- Header -->
      <header class="site-header">
        <img src="img/loreal-logo.png" alt="L'Oréal" class="logo" />
        <p class="tagline">Routine Builder</p>
        <div class="header-rule"></div>
      </header>

      <!-- Search + Filter Bar -->
      <div class="controls-bar">
        <div class="search-wrap">
          <i class="fa-solid fa-magnifying-glass search-icon"></i>
          <input type="text" id="searchInput" placeholder="Search products…" autocomplete="off" />
        </div>
        <div class="filter-wrap">
          <i class="fa-solid fa-sliders filter-icon"></i>
          <select id="categoryFilter">
            <option value="">All Categories</option>
            <option value="cleanser">Cleanser</option>
            <option value="moisturizer">Moisturizer</option>
            <option value="skincare">Skincare</option>
            <option value="haircare">Haircare</option>
            <option value="makeup">Makeup</option>
            <option value="hair color">Hair Color</option>
            <option value="hair styling">Hair Styling</option>
            <option value="men's grooming">Men's Grooming</option>
            <option value="suncare">Suncare</option>
            <option value="fragrance">Fragrance</option>
          </select>
        </div>
      </div>

      <!-- Product Grid -->
      <div id="productsContainer" class="products-grid"></div>
      <div id="noResults" class="no-results hidden">No products match your search.</div>

      <!-- Selected Products -->
      <section class="selected-section">
        <div class="selected-header">
          <h2 class="section-title">Selected Products</h2>
          <button id="clearAllBtn" class="clear-all-btn hidden">Clear All</button>
        </div>
        <div id="selectedProductsList" class="selected-list">
          <p class="empty-selected">Click any product card to add it to your routine.</p>
        </div>
        <button id="generateRoutine" class="generate-btn" disabled>
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          Generate My Routine
        </button>
      </section>

      <!-- Chat / Routine Area -->
      <section class="chatbox">
        <div class="chatbox-header">
          <h2 class="section-title">About Your Routine</h2>
          <p class="chatbox-sub">Get personalized advice and answers about your beauty routine</p>
        </div>
        <div id="chatWindow" class="chat-window">
          <div class="chat-welcome">
            <p>Select products above and click <strong>Generate My Routine</strong> to get started. Then ask me anything! ✨</p>
          </div>
        </div>
        <form id="chatForm" class="chat-form">
          <label for="userInput" class="visually-hidden">Message</label>
          <input id="userInput" name="userInput" type="text" placeholder="Ask about your routine…" autocomplete="off" required />
          <button type="submit" id="sendBtn" aria-label="Send">
            <i class="fa-solid fa-paper-plane"></i>
          </button>
        </form>
      </section>

      <!-- Description Modal -->
      <div id="descModal" class="modal-overlay hidden" role="dialog" aria-modal="true">
        <div class="modal-card">
          <button class="modal-close" id="modalClose" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
          </button>
          <div class="modal-img-wrap">
            <img id="modalImg" src="" alt="" />
          </div>
          <div class="modal-body">
            <p class="modal-brand" id="modalBrand"></p>
            <h3 class="modal-name" id="modalName"></h3>
            <span class="modal-category" id="modalCategory"></span>
            <p class="modal-desc" id="modalDesc"></p>
            <button class="modal-select-btn" id="modalSelectBtn">
              <i class="fa-solid fa-plus"></i> Add to Routine
            </button>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="site-footer">
        <p class="footer-copy">&copy; 2025 L'Oréal. All rights reserved.</p>
        <nav class="footer-nav">
          <a href="https://www.loreal.com/en/privacy-policy/" target="_blank">Privacy Policy</a>
          <span class="sep">·</span>
          <a href="https://www.loreal.com/en/terms-and-conditions/" target="_blank">Terms of Use</a>
          <span class="sep">·</span>
          <a href="https://www.loreal.com/en/contact-us/" target="_blank">Contact</a>
        </nav>
      </footer>
    </div>

    <script src="secrets.js"></script>
    <script src="script.js"></script>
  </body>
</html>
